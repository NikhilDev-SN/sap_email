PORT=4000

# heuristic is local and demo-safe. Set AI_PROVIDER=openai when you add an API key.
AI_PROVIDER=heuristic
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini

# Agent chatbot LLM. Uses the same NVIDIA NIM style as the ServiceNow agent project.
DISABLE_NVIDIA=false
NVIDIA_API_KEY=
NVIDIA_ENDPOINT=https://integrate.api.nvidia.com/v1/chat/completions
NVIDIA_DEFAULT_MODEL=nvidia/nemotron-3-super-120b-a12b
NVIDIA_TIMEOUT_MS=45000

# Mailbox used for opportunity intake. Use OAuth or a Gmail app password, not your normal password.
MAILBOX_ADDRESS=nikh.sant123@gmail.com
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:4001/auth/google/callback
GOOGLE_OAUTH_TOKEN_PATH=data/google-oauth-token.json
GMAIL_SYNC_QUERY=newer_than:30d
GMAIL_SYNC_MAX_RESULTS=10

# WhatsApp dashboard. Start QR login from the UI, then scan chats for mining sales order messages.
WHATSAPP_ENABLED=true
WHATSAPP_SESSION_PATH=data/whatsapp-session
# Optional: set this if Puppeteer cannot find Chrome/Edge automatically.
WHATSAPP_CHROME_PATH=
WHATSAPP_HEADLESS=true
WHATSAPP_CHAT_LIMIT=30
WHATSAPP_LOOKBACK_LIMIT=50
WHATSAPP_PROCESS_LIMIT=20
WHATSAPP_SEARCH_TERMS=mining sales order,minning sales order,iron ore sales order,ore sales order,coal sales order

# Opportunity persistence. Use file locally; switch to hana after SAP HANA Cloud is running.
OPPORTUNITY_STORE_BACKEND=file

# SAP HANA Cloud PO record store. The instance id alone is not enough; use a service key or binding.
HANA_INSTANCE_ID=
HANA_INSTANCE_STATUS=
HANA_SERVICE_KEY_NAME=
# password uses HANA_USER/HANA_PASSWORD. uaa-jwt uses HANA_UAA_URL/HANA_CLIENT_ID/HANA_CLIENT_SECRET.
HANA_AUTH_MODE=password
HANA_HOST=
HANA_PORT=443
HANA_USER=
HANA_PASSWORD=
HANA_UAA_URL=
HANA_CLIENT_ID=
HANA_CLIENT_SECRET=
# Keep false unless HANA JWT trust/user mapping has been configured in the database.
HANA_ENABLE_NATIVE_JWT=false
HANA_SCHEMA=
HANA_TABLE=PO_RECORDS
HANA_ENCRYPT=true
HANA_VALIDATE_CERTIFICATE=true

# mock creates a simulated SAP document. Set SAP_MODE=live after wiring SAP credentials/destination.
SAP_MODE=mock
# auto maps customer inquiries to salesInquiry and procurement flows to purchaseOrder.
SAP_DOCUMENT_TYPE=auto
# dry-run builds the SAP payload without posting. Set commit only after the real tenant is ready.
SAP_SUBMIT_MODE=dry-run

# Live SAP OData settings. In BTP, set SAP_DESTINATION_NAME and bind Destination service.
# When SAP_DESTINATION_NAME is set, it takes precedence over SAP_BASE_URL and raw credentials.
SAP_DESTINATION_NAME=

# Direct local/SAP sandbox fallback. For a real tenant, use the S/4HANA API host from SAP_COM_0109.
SAP_BASE_URL=https://your-s4hana-host.example
SAP_SERVICE_PATH=/sap/opu/odata/sap/API_SALES_INQUIRY_SRV/A_SalesInquiry
SAP_API_KEY=
SAP_USERNAME=
SAP_PASSWORD=
CONTACT_EMAIL=

# Optional business defaults used when mapping live payloads.
SAP_SALES_ORG=1000
SAP_DISTRIBUTION_CHANNEL=10
SAP_DIVISION=00
SAP_TRANSACTION_CURRENCY=
SAP_QUANTITY_UNIT=
SAP_PURCHASING_ORG=1000
SAP_PURCHASING_GROUP=001
SAP_COMPANY_CODE=1000
